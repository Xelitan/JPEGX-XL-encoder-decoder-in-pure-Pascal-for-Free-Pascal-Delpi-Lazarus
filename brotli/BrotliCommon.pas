function BrotliMaxBackwardLimit(w: uint32_t): size_t; inline;
begin
  Result := (size_t(1) shl w) - BROTLI_WINDOW_GAP;
end;

function BrotliCalculateDistanceCodeLimit(max_distance, npostfix, ndirect: uint32_t): TBrotliDistanceCodeLimit;
var
  forbidden_distance, offset, ndistbits, tmp, half, group, postfix, extra, start: uint32_t;
begin
  if max_distance <= ndirect then begin
    Result.max_alphabet_size := max_distance + BROTLI_NUM_DISTANCE_SHORT_CODES;
    Result.max_distance := max_distance;
    Exit;
  end;
  forbidden_distance := max_distance + 1;
  offset := forbidden_distance - ndirect - 1;
  ndistbits := 0;
  postfix := (uint32_t(1) shl npostfix) - 1;
  offset := (offset shr npostfix) + 4;
  tmp := offset div 2;
  while tmp <> 0 do begin Inc(ndistbits); tmp := tmp shr 1; end;
  Dec(ndistbits);
  half := (offset shr ndistbits) and 1;
  group := ((ndistbits - 1) shl 1) or half;
  if group = 0 then begin
    Result.max_alphabet_size := ndirect + BROTLI_NUM_DISTANCE_SHORT_CODES;
    Result.max_distance := ndirect;
    Exit;
  end;
  Dec(group);
  ndistbits := (group shr 1) + 1;
  extra := (uint32_t(1) shl ndistbits) - 1;
  start := (uint32_t(1) shl (ndistbits + 1)) - 4;
  start := start + ((group and 1) shl ndistbits);
  Result.max_alphabet_size := ((group shl npostfix) or postfix) + ndirect + BROTLI_NUM_DISTANCE_SHORT_CODES + 1;
  Result.max_distance := ((start + extra) shl npostfix) + postfix + ndirect + 1;
end;

function BrotliContextLut(mode: TContextType): PByte; inline;
begin
  Result := @kBrotliContextLookupTable[Ord(mode) shl 9];
end;

function BrotliContext(p1, p2: uint8_t; lut: PByte): uint8_t; inline;
begin
  Result := lut[p1] or lut[256 + p2];
end;

end.
